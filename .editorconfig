# Charmeleon C# style. Enforced by `dotnet format` (see .github/workflows/format.yml)
# and by the in-build analyzers (EnforceCodeStyleInBuild in the csproj).
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# Machine-generated: never reformat or lint.
[*.Designer.cs]
generated_code = true

[*.{g,g.i}.cs]
generated_code = true

[*.cs]
# using directives: System.* first, one group.
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Runtime style: do not require `this.` qualification.
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# `var`: allow but do not force.
csharp_style_var_for_built_in_types = false:silent
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_var_elsewhere = false:silent

# Allman braces.
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# Expression-bodied members: allowed, not forced.
csharp_style_expression_bodied_methods = true:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_accessors = true:silent

# Namespaces, usings.
csharp_style_namespace_declarations = block_scoped:silent
csharp_using_directive_placement = outside_namespace:silent

# ---- Naming (the cases the code already follows) ----
# const fields are exempt from the _ prefix (they follow PascalCase / SDK naming).
dotnet_naming_rule.const_fields_pascal.severity = silent
dotnet_naming_rule.const_fields_pascal.symbols  = const_fields
dotnet_naming_rule.const_fields_pascal.style    = pascal
dotnet_naming_symbols.const_fields.applicable_kinds = field
dotnet_naming_symbols.const_fields.applicable_accessibilities = *
dotnet_naming_symbols.const_fields.required_modifiers = const

# private instance fields -> _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols  = private_fields
dotnet_naming_rule.private_fields_underscore.style    = underscore_camel
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.underscore_camel.capitalization  = camel_case

# interfaces -> IPascalCase
dotnet_naming_rule.interfaces_prefixed.severity = warning
dotnet_naming_rule.interfaces_prefixed.symbols  = interface_symbols
dotnet_naming_rule.interfaces_prefixed.style    = i_prefixed
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.i_prefixed.required_prefix = I
dotnet_naming_style.i_prefixed.capitalization  = pascal_case

# public/protected/internal members and types -> PascalCase (hint only for now;
# there is one legacy exception, the `aboutForm` type).
dotnet_naming_rule.members_pascal.severity = suggestion
dotnet_naming_rule.members_pascal.symbols  = public_members
dotnet_naming_rule.members_pascal.style    = pascal
dotnet_naming_symbols.public_members.applicable_kinds = class,struct,enum,interface,property,method,event
dotnet_naming_symbols.public_members.applicable_accessibilities = public,internal,protected
dotnet_naming_style.pascal.capitalization = pascal_case
